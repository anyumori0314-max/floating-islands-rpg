*.usertasks

# ==============================
# IDE
# ==============================
.vs/
.idea/

# VS Code personal settings (keep shared settings via allowlist if needed)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# No shared VS Code config is committed yet, so the allowlist above currently
# leaves settings.json/tasks.json/launch.json/extensions.json untracked and
# noisy in `git status`. This later, more specific rule re-ignores the whole
# folder (gitignore uses the last matching rule); it only affects untracked
# files and does not untrack anything already committed. Remove this line if
# any of the allowlisted files above are intentionally committed later.
/.vscode/

